# Production deployment template
# Copy to .env.production and fill in real values before running ./setup.sh or pnpm deploy:cf.

# AWS runtime credentials uploaded to the deployed Worker
AWS_REGION=us-west-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# Optional: required when using temporary STS / AWS SSO-derived credentials
AWS_SESSION_TOKEN=

# AWS deploy metadata
CDK_DEFAULT_ACCOUNT=123456789012
CDK_DEFAULT_REGION=us-west-1
CLOUDFORMATION_STACK_NAME=MinecraftStack
INSTANCE_ID=i-1234567890abcdef0
KEY_PAIR_NAME=mc-aws

# Google OAuth
GOOGLE_CLIENT_ID=123456789-abcdefg.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-abc123xyz789

# Auth and panel config
ADMIN_EMAIL=your-email@gmail.com
ALLOWED_EMAILS=friend1@gmail.com,friend2@gmail.com
NEXT_PUBLIC_APP_URL=https://panel.yourdomain.com
# Auto-generated during setup/deploy if left as a placeholder
AUTH_SECRET=your-secret-here

# Cloudflare DNS runtime config
CLOUDFLARE_DNS_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ZONE_ID=your-zone-id
# Optional on first deploy: deploy script can create and persist the record id for you
CLOUDFLARE_RECORD_ID=
CLOUDFLARE_MC_DOMAIN=mc.yourdomain.com

# Runtime-state KV ids
# Optional on first deploy: deploy script can create and persist these ids for you
RUNTIME_STATE_SNAPSHOT_KV_ID=
RUNTIME_STATE_SNAPSHOT_KV_PREVIEW_ID=

# Durable operation-state retention
MC_OPERATION_STATE_RETENTION_DAYS=30

# Optional SES email features
VERIFIED_SENDER=start@yourdomain.com
NOTIFICATION_EMAIL=your-email@gmail.com
START_KEYWORD=startserver123

# GitHub-backed server config sync
GITHUB_USER=yourusername
GITHUB_REPO=yourrepo
GITHUB_TOKEN=ghp_yourtoken

# Google Drive backups
GDRIVE_REMOTE=gdrive
GDRIVE_ROOT=mc-backups
