# Local AWS development template
# Copy to .env.local when you want to run the panel locally against real AWS.
# For offline development, use .env.mock.example instead.

# AWS credentials for local API routes
AWS_REGION=us-west-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# Optional: required when using temporary STS / AWS SSO-derived credentials
AWS_SESSION_TOKEN=
INSTANCE_ID=i-1234567890abcdef0

# Optional stack lookup override
CLOUDFORMATION_STACK_NAME=MinecraftStack

# Local auth and panel URL
# pnpm dev already enables ENABLE_DEV_LOGIN=true for convenience.
AUTH_SECRET=dev-secret-change-in-production
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_EMAIL=your-email@gmail.com
ALLOWED_EMAILS=friend1@gmail.com,friend2@gmail.com

# Optional Google OAuth for local sign-in (dev login also works)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Required for start/resume flows that update Minecraft DNS
CLOUDFLARE_DNS_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ZONE_ID=your-zone-id
CLOUDFLARE_RECORD_ID=your-record-id
CLOUDFLARE_MC_DOMAIN=mc.yourdomain.com

# Optional operations features
MC_OPERATION_STATE_RETENTION_DAYS=30
VERIFIED_SENDER=
NOTIFICATION_EMAIL=
START_KEYWORD=
GDRIVE_REMOTE=gdrive
GDRIVE_ROOT=mc-backups
